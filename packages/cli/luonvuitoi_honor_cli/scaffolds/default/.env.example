# Admin login. Required to use /admin + the write API. If ADMIN_PASSWORD is unset,
# the admin surface stays locked. SECRET_KEY signs the session cookie — set a long
# random value in production so logins survive restarts.
ADMIN_PASSWORD=
SECRET_KEY=

# Optional deploy knobs (all safe to leave unset for local dev).

# Pin the public origin so generated links/QRs can't be Host-header spoofed.
# PUBLIC_BASE_URL=https://your-honor-roll.vercel.app

# Force HSTS when deployed behind HTTPS.
# FORCE_HSTS=1
