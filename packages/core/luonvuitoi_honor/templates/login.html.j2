{% extends "base.html.j2" %}
{% block nav_roll %}{% endblock %}{% block nav_login %}active{% endblock %}
{% block styles %}
.login-box{max-width:400px;margin:24px auto;background:#fff;border:3px solid var(--line);border-radius:24px;padding:30px;box-shadow:0 10px 0 rgba(60,40,120,.10);text-align:center}
.login-box h2{font-family:'Baloo 2',cursive;font-size:1.5em;color:var(--ink);margin-bottom:4px}
.login-box .sub{color:var(--muted);font-weight:700;font-size:.9em;margin-bottom:20px}
.login-box label{font-size:.76em;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;display:block;margin-bottom:6px;text-align:left}
.login-box input{width:100%;border:3px solid var(--line);border-radius:14px;padding:12px 14px;font-size:1.05em;font-family:inherit;font-weight:700;margin-bottom:16px;color:var(--ink)}
.login-box input:focus-visible{border-color:var(--primary)}
.login-box button{width:100%;background:var(--primary);color:#fff;border:none;border-radius:14px;padding:13px;font-weight:800;cursor:pointer;font-size:1.05em;box-shadow:0 5px 0 rgba(0,0,0,.18);transition:transform .12s}
.login-box button:hover:not(:disabled){transform:translateY(-2px)}
.login-box button:active:not(:disabled){transform:translateY(3px);box-shadow:0 2px 0 rgba(0,0,0,.18)}
.login-box button:disabled{opacity:.5;cursor:not-allowed}
.login-err{background:#fee2e2;color:#b91c1c;border-radius:12px;padding:10px 12px;font-size:.88em;font-weight:800;margin-bottom:16px}
.login-warn{background:#fef3c7;color:#92400e;border-radius:12px;padding:10px 12px;font-size:.86em;font-weight:700;margin-bottom:16px}
{% endblock %}
{% block content %}
<div class="login-box">
  <h2>🔐 {{ locale.admin.login }}</h2>
  <div class="sub">{{ locale.admin.title }}</div>
  {% if locked_out %}<div class="login-err" role="alert">{{ locale.admin.login_locked }} {{ retry_after }}s</div>{% endif %}
  {% if login_error %}<div class="login-err" role="alert">{{ locale.admin.login_error }}</div>{% endif %}
  {% if not admin_configured %}<div class="login-warn" role="alert">{{ locale.admin.login_unconfigured }}</div>{% endif %}
  <form method="post" action="/login">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <label for="pw">{{ locale.admin.password }}</label>
    <input id="pw" type="password" name="password" autocomplete="current-password" required autofocus {{ 'disabled' if not admin_configured }}>
    <button type="submit" {{ 'disabled' if not admin_configured }}>{{ locale.admin.login }}</button>
  </form>
</div>
{% endblock %}
