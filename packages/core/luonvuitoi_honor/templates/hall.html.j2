{% extends "base.html.j2" %}
{% block nav_roll %}{% endblock %}{% block nav_hall %}active{% endblock %}
{% block styles %}
.hof-hero{text-align:center;margin-bottom:26px}
.hof-hero h2{font-family:'Baloo 2',cursive;font-size:1.7em;color:var(--ink)}
.hof-hero p{color:var(--muted);font-weight:700;margin-top:4px}
.hof-grid{display:grid;gap:20px;grid-template-columns:repeat(auto-fill,minmax(220px,1fr))}
.hof-card{display:block;text-decoration:none;background:#fff;border:3px solid var(--line);border-top:8px solid var(--mc,var(--primary));border-radius:22px;padding:22px 16px 18px;text-align:center;box-shadow:0 8px 0 rgba(60,40,120,.10);transition:transform .18s,box-shadow .18s;position:relative}
.hof-card:hover{transform:translateY(-6px) rotate(-1deg);box-shadow:0 16px 30px rgba(60,40,120,.20)}
.hof-card:focus-visible{outline:3px solid var(--sun);outline-offset:3px}
.hof-rank{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--sun),var(--tangerine));color:#3a2e00;font-family:'Baloo 2',cursive;font-weight:800;border-radius:999px;padding:3px 16px;font-size:.9em;box-shadow:0 3px 0 rgba(0,0,0,.14)}
.hof-card .avatar{width:84px;height:84px;border-radius:50%;object-fit:cover;display:block;margin:6px auto 0;border:4px solid var(--mc,var(--primary));box-shadow:0 5px 12px rgba(0,0,0,.14)}
.hof-card .ico{font-size:3em;line-height:1;margin-top:6px}
.hof-card .nm{font-family:'Baloo 2',cursive;font-weight:700;font-size:1.14em;color:var(--ink);margin-top:8px;text-wrap:balance}
.hof-card .sub{font-size:.82em;font-weight:700;color:var(--muted);margin-top:3px}
.hof-card .badge{display:inline-block;margin-top:10px;padding:5px 14px;border-radius:999px;color:#fff;font-size:.76em;font-weight:800;box-shadow:0 3px 0 rgba(0,0,0,.14)}
.hof-card .cnt{display:block;margin-top:8px;font-weight:800;color:var(--primary)}
.empty{text-align:center;padding:54px 20px;color:var(--muted);font-weight:700}
.empty .big{font-size:3.4em;display:inline-block;animation:wiggle 2.5s ease-in-out infinite}
{% endblock %}
{% block content %}
<div class="hof-hero">
  <h2>🏛️ {{ locale.hall.title }}</h2>
  <p>{{ locale.hall.subtitle }}</p>
</div>
{% if stars %}
<div class="hof-grid">
  {% for s in stars %}
  <a class="hof-card" style="--mc:{{ s.medal_color }}" href="/search?q={{ s.name | urlencode }}" aria-label="{{ s.name }}">
    {% if loop.index <= 3 %}<span class="hof-rank">#{{ loop.index }}</span>{% endif %}
    {% if s.photo_url %}<img class="avatar" src="{{ s.photo_url }}" alt="{{ s.name }}" width="84" height="84" loading="lazy">{% else %}<div class="ico" aria-hidden="true">{{ s.medal_icon }}</div>{% endif %}
    <div class="nm">{{ s.name }}</div>
    {% if s.grade %}<div class="sub">{{ locale.roll.grade_label }} {{ s.grade }}</div>{% endif %}
    {% if s.school %}<div class="sub">{{ s.school }}</div>{% endif %}
    <span class="badge" style="background:{{ s.medal_color }}">{{ s.medal_icon }} {{ s.medal_label }}</span>
    <span class="cnt">🏅 {{ s.count }} {{ locale.hall.medals }}</span>
  </a>
  {% endfor %}
</div>
{% else %}
<div class="empty"><div class="big" aria-hidden="true">🏛️</div><p style="margin-top:12px">{{ locale.hall.empty }}</p></div>
{% endif %}
{% endblock %}
