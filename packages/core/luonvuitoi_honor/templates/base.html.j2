<!DOCTYPE html>
<html lang="{{ locale_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="{{ primary_color }}">
  <title>{{ page_title }} · {{ project_name }}</title>
  {% if public_base_url %}<link rel="canonical" href="{{ public_base_url }}">
  <meta property="og:url" content="{{ public_base_url }}">{% endif %}
  <meta property="og:title" content="{{ page_title }} · {{ project_name }}">
  {% if logo_url %}<link rel="icon" href="{{ logo_url }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;600;700;800&display=swap&subset=vietnamese,latin-ext" rel="stylesheet">
  <style>
    :root{
      --primary:{{ primary_color }};--accent:{{ accent_color }};
      --sun:#ffd23f;--leaf:#34d399;--sky:#38bdf8;--bubble:#fb7185;--grape:#a78bfa;--tangerine:#fb923c;
      --ink:#3a3266;--muted:#7c75a3;--paper:#fffdf7;--line:#efe9ff;
      color-scheme:light;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    a,button{touch-action:manipulation;-webkit-tap-highlight-color:transparent}
    a:focus-visible,button:focus-visible,input:focus-visible,select:focus-visible{
      outline:3px solid var(--sun);outline-offset:2px;border-radius:10px;
    }
    body{
      font-family:'Nunito','Segoe UI',Tahoma,sans-serif;font-weight:600;
      background:linear-gradient(-45deg,var(--primary),var(--accent),#56ccf2,#ffd23f);
      background-size:400% 400%;animation:bgshift 22s ease infinite;
      min-height:100vh;padding:22px 16px;color:var(--ink);position:relative;overflow-x:hidden;
    }
    /* Playful floating shapes behind the card (decorative). */
    body::before,body::after{content:"";position:fixed;border-radius:50%;filter:blur(6px);opacity:.55;z-index:0;pointer-events:none;
      background:radial-gradient(circle at 30% 30%,#fff8,transparent 60%)}
    body::before{width:180px;height:180px;top:8%;left:4%;background:var(--sun);animation:floaty 7s ease-in-out infinite}
    body::after{width:140px;height:140px;bottom:10%;right:6%;background:var(--bubble);animation:floaty 9s ease-in-out infinite}
    @keyframes bgshift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    @keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
    @keyframes pop{0%{transform:scale(.8)}60%{transform:scale(1.08)}100%{transform:scale(1)}}
    @keyframes wiggle{0%,100%{transform:rotate(-3deg)}50%{transform:rotate(3deg)}}
    .skip{position:absolute;left:-999px;top:8px;background:#fff;color:var(--primary);padding:8px 14px;border-radius:12px;font-weight:800;z-index:100}
    .skip:focus{left:16px}
    .container{
      position:relative;z-index:1;max-width:1180px;margin:0 auto;background:var(--paper);
      border-radius:32px;border:4px solid #fff;
      box-shadow:0 24px 70px rgba(60,40,120,.32);overflow:hidden;animation:fadeUp .6s ease-out;
    }
    .header{
      background:linear-gradient(135deg,var(--primary),var(--accent));
      color:#fff;padding:38px 26px 30px;text-align:center;position:relative;overflow:hidden;
    }
    .header .sparkles{font-size:1.3em;letter-spacing:.5em;opacity:.9;margin-bottom:6px}
    .header h1{font-family:'Baloo 2',cursive;font-size:2.5em;font-weight:800;line-height:1.05;
      text-shadow:0 3px 0 rgba(0,0,0,.18);text-wrap:balance}
    .header p{margin-top:8px;font-weight:700;font-size:1.06em;opacity:.96;text-wrap:pretty}
    .nav{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:18px}
    .nav a{
      color:var(--primary);text-decoration:none;background:#fff;
      padding:9px 18px;border-radius:999px;font-size:.92em;font-weight:800;
      transition:transform .15s ease,box-shadow .15s ease;box-shadow:0 4px 0 rgba(0,0,0,.12);
    }
    .nav a:hover{transform:translateY(-2px) rotate(-2deg);box-shadow:0 6px 0 rgba(0,0,0,.16)}
    .nav a:active{transform:translateY(2px);box-shadow:0 2px 0 rgba(0,0,0,.12)}
    .nav a.active{background:var(--sun);color:var(--ink)}
    .lang-switch{position:absolute;top:14px;right:16px;display:flex;gap:5px;z-index:2}
    .lang-switch a{color:#fff;text-decoration:none;font-weight:800;font-size:.76em;padding:4px 10px;border-radius:999px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.35)}
    .lang-switch a.on{background:#fff;color:var(--primary)}
    .body{padding:28px 22px 36px}
    .footer{padding:20px;text-align:center;color:var(--muted);font-size:.84em;font-weight:700;border-top:3px dotted var(--line)}
    .footer .contact{margin-bottom:6px;color:var(--ink)}
    .footer .contact a{color:var(--primary);font-weight:800;text-decoration:none}
    @media(max-width:560px){.header h1{font-size:2em}}
    @media (prefers-reduced-motion: reduce){
      *,*::before,*::after{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important}
    }
    {% block styles %}{% endblock %}
  </style>
</head>
<body>
  <a class="skip" href="#main">{{ locale.search.title }}</a>
  <div class="container">
    <header class="header">
      <div class="lang-switch" aria-label="Language / Ngôn ngữ">
        <a href="?lang=vi" class="{{ 'on' if locale_code == 'vi' }}" hreflang="vi">VI</a>
        <a href="?lang=en" class="{{ 'on' if locale_code == 'en' }}" hreflang="en">EN</a>
      </div>
      <div class="sparkles" aria-hidden="true">⭐ 🎉 ⭐</div>
      <h1><span aria-hidden="true">🏆</span> {{ project_name }} <span aria-hidden="true">🏆</span></h1>
      <p>{{ tagline }}</p>
      <nav class="nav">
        {% if admin_area %}
        <a href="/">🏠 {{ locale.roll.title }}</a>
        {% if admin_authed %}
        <a href="/admin" class="{% block nav_admin %}{% endblock %}">⚙️ {{ locale.admin.title }}</a>
        <a href="/logout">🚪 {{ locale.admin.logout }}</a>
        {% endif %}
        {% else %}
        <a href="/" class="{% block nav_roll %}active{% endblock %}">🏅 {{ locale.roll.title }}</a>
        <a href="/search" class="{% block nav_search %}{% endblock %}">🔍 {{ locale.search.title }}</a>
        <a href="/hall-of-fame" class="{% block nav_hall %}{% endblock %}">🏛️ {{ locale.hall.title }}</a>
        {% if show_teams %}<a href="/teams" class="{% block nav_teams %}{% endblock %}">⭐ {{ locale.teams.title }}</a>{% endif %}
        {% endif %}
      </nav>
    </header>
    <main class="body" id="main">{% block content %}{% endblock %}</main>
    <footer class="footer">
      {% if contact and (contact.email or contact.phone or contact.note) %}
      <div class="contact">📞 {% if contact.note %}{{ contact.note }}{% endif %}{% if contact.email %} · <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>{% endif %}{% if contact.phone %} · {{ contact.phone }}{% endif %}</div>
      {% endif %}
      {{ locale.footer.powered_by }}
      {% if contact and contact.repo_url %} · <a href="{{ contact.repo_url }}" target="_blank" rel="noopener">⭐ GitHub</a>{% endif %}
    </footer>
  </div>
  {% block scripts %}{% endblock %}
</body>
</html>
