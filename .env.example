# Copy to .env and fill in values. Never commit .env.

# Admin login. Required to access /admin and the write API. If ADMIN_PASSWORD is
# unset, the admin surface stays locked (login disabled). SECRET_KEY signs the
# session cookie — set a long random value in production so logins survive restarts.
ADMIN_PASSWORD=
SECRET_KEY=

# Public base URL used when building links. Pin to your real deploy origin so
# the Host header can't be spoofed.
PUBLIC_BASE_URL=https://your-domain.example

# Comma-separated list of origins allowed to call /api/*. Use "*" only when the
# portal is public and does not serve authenticated cookies.
ALLOWED_ORIGINS=https://your-domain.example

# Emit Strict-Transport-Security header on every response. Enable only when the
# site is served exclusively over HTTPS — HSTS is cached by browsers.
FORCE_HSTS=0

# Trust the X-Forwarded-For header for client IP. Set to 1 ONLY when deploying
# behind a reverse proxy that overwrites it (Nginx, Caddy, Vercel, Cloud Run).
TRUST_PROXY_HEADERS=0
